<!--
  Wazuh Agent Configuration — ossec.conf
  
  This is a sanitized example of the agent config used in this lab.
  Location on endpoint: /var/ossec/etc/ossec.conf
  
  Replace [WAZUH_SERVER_IP] with your actual Wazuh Manager IP address.
-->

<ossec_config>

  <!-- ============================================================
       SERVER CONNECTION
       Tells the agent where to send its data
  ============================================================ -->
  <client>
    <server>
      <address>[WAZUH_SERVER_IP]</address>
      <port>1514</port>
      <protocol>tcp</protocol>
    </server>
    <config-profile>ubuntu, ubuntu22</config-profile>
    <notify_time>10</notify_time>
    <time-reconnect>60</time-reconnect>
    <auto_restart>yes</auto_restart>
    <crypto_method>aes</crypto_method>
  </client>

  <!-- ============================================================
       LOG MONITORING
       Defines which log files on the endpoint to collect
  ============================================================ -->

  <!-- Authentication events: SSH logins, sudo, su -->
  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/auth.log</location>
  </localfile>

  <!-- General system messages -->
  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/syslog</location>
  </localfile>

  <!-- Package install/remove history -->
  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/dpkg.log</location>
  </localfile>

  <!-- Kernel messages (useful for UFW firewall logs) -->
  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/kern.log</location>
  </localfile>

  <!-- ============================================================
       FILE INTEGRITY MONITORING (FIM)
       Alerts when important files are created, modified, or deleted
  ============================================================ -->
  <syscheck>
    <!-- How often to run a full FIM scan (in seconds) -->
    <frequency>300</frequency>

    <!-- Alert on first scan when new files are found -->
    <alert_new_files>yes</alert_new_files>

    <!-- Directories to monitor — checks all attributes -->
    <directories check_all="yes" report_changes="yes">/etc</directories>
    <directories check_all="yes">/usr/bin,/usr/sbin</directories>
    <directories check_all="yes">/bin,/sbin</directories>

    <!-- Directories to ignore (noisy, low value) -->
    <ignore>/etc/mtab</ignore>
    <ignore>/etc/hosts.deny</ignore>
    <ignore>/etc/mail/statistics</ignore>
    <ignore>/etc/random-seed</ignore>
    <ignore>/etc/adjtime</ignore>
    <ignore>/etc/resolv.conf</ignore>
  </syscheck>

  <!-- ============================================================
       ROOTKIT DETECTION
       Scans for signs of rootkits and hidden malware
  ============================================================ -->
  <rootcheck>
    <disabled>no</disabled>
    <check_files>yes</check_files>
    <check_trojans>yes</check_trojans>
    <check_dev>yes</check_dev>
    <check_sys>yes</check_sys>
    <check_pids>yes</check_pids>
    <check_ports>yes</check_ports>
    <check_if>yes</check_if>
    <frequency>43200</frequency>  <!-- Every 12 hours -->
  </rootcheck>

  <!-- ============================================================
       ACTIVE RESPONSE
       Set to disabled in this lab to allow full attack observation
       Enable in production to automatically block malicious IPs
  ============================================================ -->
  <active-response>
    <disabled>yes</disabled>
  </active-response>

  <!-- ============================================================
       SYSTEM INVENTORY
       Collects hardware, OS, package, and network info
  ============================================================ -->
  <wodle name="syscollector">
    <disabled>no</disabled>
    <interval>1h</interval>
    <scan_on_start>yes</scan_on_start>
    <hardware>yes</hardware>
    <os>yes</os>
    <network>yes</network>
    <packages>yes</packages>
    <ports all="no">yes</ports>
    <processes>yes</processes>
  </wodle>

</ossec_config>
